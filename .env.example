# ---------------------------------------------------------------------------
# gemini-openai-proxy configuration
# Copy this file to .env and fill in the values you need.
# Every variable is optional unless marked "required".
# ---------------------------------------------------------------------------

# HTTP port the proxy listens on (inside the container and on the host).
PORT=11434

# Auth mode. One of: oauth-personal | gemini-api-key | vertex-ai
AUTH_TYPE=oauth-personal

# API key. Required when AUTH_TYPE=gemini-api-key.
# Also required for /v1/embeddings when AUTH_TYPE=oauth-personal
# (Google's embed endpoint is API-key-only).
GEMINI_API_KEY=

# Fixed port for the OAuth2 callback HTTP server.
# Only used with AUTH_TYPE=oauth-personal. Does NOT need to be exposed
# outside the container if you complete login via the Telegram bot
# paste-URL flow.
OAUTH_CALLBACK_PORT=8085

# Optional override of the upstream gemini-cli OAuth client credentials.
# Usually leave blank — the proxy reuses the values bundled with
# @google/gemini-cli. Set both if you want to use your own Google Cloud
# OAuth client.
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=

# Whitelist of models exposed via the OpenAI proxy. The client picks one
# per request via OpenAI's `model` field; any value outside this list is
# rejected with HTTP 400 — the proxy never substitutes a default.
# Leave empty to expose the full Code Assist (oauth-personal) catalog:
#   gemini-3.1-pro-preview
#   gemini-3-flash-preview
#   gemini-3.1-flash-lite-preview
#   gemini-2.5-pro
#   gemini-2.5-flash
#   gemini-2.5-flash-lite
#
# Separators are flexible — commas, spaces, and newlines all work.
# Pick whichever style you like; docker compose passes the value through
# unchanged via env_file.
#
# Single value:
#   MODEL=gemini-2.5-pro
#
# Comma-separated:
#   MODEL=gemini-2.5-pro,gemini-2.5-flash,gemini-3.1-pro-preview
#
# Multi-line list (use quotes):
#   MODEL="
#   gemini-2.5-pro
#   gemini-2.5-flash
#   gemini-3.1-pro-preview
#   "
MODEL=

# Optional gemini-cli version string used for User-Agent impersonation.
# Defaults to 0.39.0 if unset.
CLI_VERSION=

# ---------------------------------------------------------------------------
# Telegram bot (optional: login helper + health monitoring)
# Set BOTH values to enable. Only messages from TELEGRAM_USER_ID are answered.
# ---------------------------------------------------------------------------

# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user id (ask @userinfobot).
TELEGRAM_USER_ID=
